{
  "info": {
    "name": "Finance Backend API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Admin\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"admin\"\n}"
            }
          }
        },
        {
          "name": "Register Analyst",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bob Analyst\",\n  \"email\": \"bob@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"analyst\"\n}"
            }
          }
        },
        {
          "name": "Register Viewer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Carol Viewer\",\n  \"email\": \"carol@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"viewer\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) pm.collectionVariables.set('token', res.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/users/me"
          }
        },
        {
          "name": "Get All Users (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/users?page=1&limit=10",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "role", "value": "analyst", "disabled": true },
                { "key": "status", "value": "active", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get User by ID (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/users/USER_ID_HERE"
          }
        },
        {
          "name": "Update User (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/users/USER_ID_HERE",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"analyst\",\n  \"status\": \"inactive\"\n}"
            }
          }
        },
        {
          "name": "Delete User (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/users/USER_ID_HERE"
          }
        }
      ]
    },
    {
      "name": "Records",
      "item": [
        {
          "name": "Create Record (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/records",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 5000,\n  \"type\": \"income\",\n  \"category\": \"Salary\",\n  \"date\": \"2024-06-01\",\n  \"note\": \"Monthly salary for June\"\n}"
            }
          }
        },
        {
          "name": "Create Expense Record (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/records",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 1200,\n  \"type\": \"expense\",\n  \"category\": \"Rent\",\n  \"date\": \"2024-06-05\",\n  \"note\": \"Monthly rent payment\"\n}"
            }
          }
        },
        {
          "name": "Get All Records (Analyst/Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/records?page=1&limit=10",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "type", "value": "expense", "disabled": true },
                { "key": "category", "value": "Rent", "disabled": true },
                { "key": "startDate", "value": "2024-01-01", "disabled": true },
                { "key": "endDate", "value": "2024-12-31", "disabled": true },
                { "key": "sortBy", "value": "amount", "disabled": true },
                { "key": "order", "value": "desc", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Record by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/records/RECORD_ID_HERE"
          }
        },
        {
          "name": "Update Record (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/records/RECORD_ID_HERE",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 5500,\n  \"note\": \"Updated salary after raise\"\n}"
            }
          }
        },
        {
          "name": "Soft Delete Record (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/records/RECORD_ID_HERE"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Full Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/dashboard"
          }
        },
        {
          "name": "Summary (Income/Expense/Balance)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/dashboard/summary"
          }
        },
        {
          "name": "Category Totals",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/dashboard/categories",
              "query": [
                { "key": "type", "value": "expense", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Recent Transactions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/dashboard/recent"
          }
        },
        {
          "name": "Monthly Trends",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/dashboard/trends?year=2024",
              "query": [
                { "key": "year", "value": "2024" }
              ]
            }
          }
        }
      ]
    }
  ]
}
